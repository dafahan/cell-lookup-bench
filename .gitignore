# Secrets — never commit. Rotate any key that has ever been committed.
.env
.env.*
!.env.example
*.key
*credentials*

# Python environment
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/

# Response cache: keyed by prompt hash, regenerated on demand. The published
# run_*.json files already contain every response needed to reproduce the tables.
results/cache*.json

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
